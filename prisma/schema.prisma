generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ConsultationStatus {
  NEW
  ACCEPTED
  REJECTED
  CHANGED
}

model User {
  id              Int       @id @default(autoincrement())
  fullName        String
  email           String    @unique
  passwordHash    String
  role            Role      @default(USER)
  isActive        Boolean   @default(true)
  trialStartDate  DateTime  @default(now())
  trialExpiryDate DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions   Subscription[]
  consultations   Consultation[]
  paymentRequests PaymentRequest[]
  educationalContentUpdates EducationalContentOverride[] @relation("EducationalContentUpdatedBy")
  contentCustomizations UserContentCustomization[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     Item[]
}

model Item {
  id         Int      @id @default(autoincrement())
  categoryId Int
  title      String
  speechText String
  imageUrl   String
  audioUrl   String?
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category   Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants   ItemVariant[]
}

model ItemVariant {
  id         Int      @id @default(autoincrement())
  itemId     Int
  title      String
  speechText String
  imageUrl   String
  audioUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model PaymentRequest {
  id          Int           @id @default(autoincrement())
  userId      Int
  userName    String?
  userEmail   String?
  packageName String
  price       String
  receiptUrl  String
  status      RequestStatus @default(PENDING)
  decidedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription?

  @@index([userId, status])
}

model Subscription {
  id               Int      @id @default(autoincrement())
  userId           Int
  paymentRequestId Int?     @unique
  status           String   @default("active")
  planName         String?
  planMonths       Int?
  amount           String?
  startDate        DateTime @default(now())
  expiryDate       DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentRequest PaymentRequest? @relation(fields: [paymentRequestId], references: [id], onDelete: SetNull)

  @@index([userId, status, expiryDate])
}

model Consultation {
  id         Int                @id @default(autoincrement())
  userId     Int?
  userName   String?
  userEmail  String?
  specialist String
  message    String?
  status     ConsultationStatus @default(NEW)
  date       DateTime?
  time       String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model JourneyStep {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model EducationalContentOverride {
  id          String   @id
  unitId      String
  title       String
  speechText  String
  imageUrl    String?
  audioUrl    String?
  isOverride  Boolean  @default(false)
  targetKey   String?
  updatedById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User @relation("EducationalContentUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([targetKey])
}

model UserContentCustomization {
  id         Int      @id @default(autoincrement())
  userId     Int
  contentKey String
  title      String
  speechText String
  imageUrl   String?
  audioUrl   String?
  data       Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentKey])
  @@index([userId])
}


model AdminNotification {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  type      String
  sourceId  Int
  route     String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, sourceId])
  @@index([isRead, createdAt])
}
